# Required
RMV_API_KEY=your_rmv_api_key_here

# Required if notifier.backend = telegram (default)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Secures the notifier webhook endpoint (validates X-Telegram-Bot-Api-Secret-Token header)
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# Required if translator.backend = google
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Required only when translator.backend=libretranslate and the instance requires auth
LIBRETRANSLATE_API_KEY=your_libretranslate_api_key_here

# Required if sports.ticketmaster_venue_id is set in config.yaml
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# Optional: Stadia Maps API key for dark mode map tiles (Alidade Smooth Dark)
STADIA_API_KEY=your_stadia_api_key_here

# for pinning
RADAR_TAG=your_radar_tag_here

# MCP server (deploy with: docker compose --profile mcp up -d)
# MCP_PORT=8811

# Umami analytics (production only — deploy with: docker compose --profile analytics up -d)
UMAMI_DB_PASSWORD=change_me_strong_password
UMAMI_APP_SECRET=change_me_random_32char_string

# Create a dedicated account in Umami: Settings -> Users.
UMAMI_USERNAME=change_me_umami_username
UMAMI_PASSWORD=change_me_umami_password
