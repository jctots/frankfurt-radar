# Required
RMV_API_KEY=your_rmv_api_key_here

# Required if notifier.backend = telegram (default)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Required if translator.backend = google
GOOGLE_TRANSLATE_API_KEY=

# Required only when translator.backend=libretranslate and the instance requires auth
#LIBRETRANSLATE_API_KEY=

# for pinning
RADAR_TAG=your_radar_tag_here